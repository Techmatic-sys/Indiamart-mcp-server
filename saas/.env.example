# --------------------------------------------------------------------------
# IndiaMART Lead Manager SaaS — Environment Variables
# Copy to .env and fill in real values before running.
# --------------------------------------------------------------------------

# ---- Database -------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/indiamart_saas

# ---- Redis ----------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---- Application secrets --------------------------------------------------
SECRET_KEY=your-secret-key-change-this-to-a-random-64-char-string

# ---- Razorpay (payments) --------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ---- OpenAI (AI features) ------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- CORS -----------------------------------------------------------------
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# ---- Email (SMTP) ---------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ---- WhatsApp via Gupshup ------------------------------------------------
GUPSHUP_API_KEY=your-gupshup-api-key
GUPSHUP_APP_NAME=your-gupshup-app-name

# ---- SMS via Twilio -------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE=+1234567890
