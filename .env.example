# ══════════════════════════════════════════════════════════════
# IndiaMART MCP Server — Environment Configuration
# ══════════════════════════════════════════════════════════════
# HOW TO GET YOUR INDIAMART API CREDENTIALS
# ══════════════════════════════════════════════════════════════
# 1. Login → seller.indiamart.com
# 2. Click Lead Manager (top nav)
# 3. Click ⚙️ Settings → CRM Integration
# 4. Copy "glusr_crm_key" → paste below as INDIAMART_API_KEY
# 5. Your GLID is shown in your account profile URL
# ══════════════════════════════════════════════════════════════

INDIAMART_API_KEY=paste_your_glusr_crm_key_here
INDIAMART_GLID=paste_your_8_digit_glid_here

# ── Optional settings (defaults work fine) ────────────────────
DB_PATH=./leads.db          # Where to store your leads locally
LOG_LEVEL=INFO              # DEBUG for troubleshooting
PORT=8000                   # Webhook server port
WEBHOOK_SECRET=             # Optional: any random string for security

# ══════════════════════════════════════════════════════════════
# SaaS Web App Settings (only needed if running the full platform)
# ══════════════════════════════════════════════════════════════
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/indiamart_saas
# REDIS_URL=redis://localhost:6379/0
# SECRET_KEY=generate-a-strong-random-key-here
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# FERNET_KEY=your_fernet_key_here
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_secret
