{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Techmatic-sys/indiamart-mcp-server",
  "description": "Manage IndiaMART buyer leads with Claude AI. Fetch, search, sync, reply and track pipeline stages using natural language.",
  "repository": {
    "url": "https://github.com/Techmatic-sys/indiamart-mcp-server",
    "source": "github"
  },
  "version": "1.1.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "indiamart-mcp-server",
      "version": "1.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "INDIAMART_API_KEY",
          "description": "Your IndiaMART CRM API key from Lead Manager settings",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "INDIAMART_GLID",
          "description": "Your IndiaMART Global Login ID",
          "isRequired": true,
          "isSecret": false,
          "format": "string"
        }
      ]
    }
  ]
}
